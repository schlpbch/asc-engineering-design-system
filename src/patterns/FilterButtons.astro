---
export interface Props {
  label?: string;
  filters: Array<{
    id: string;
    label: string;
    active?: boolean;
  }>;
  multiSelect?: boolean;
  containerClass?: string;
}

const { label = 'Filter by:', filters, multiSelect = false, containerClass = '' } = Astro.props;
const containerId = `filter-container-${Math.random().toString(36).substring(2, 11)}`;
---

<div
  id={containerId}
  data-multi-select={multiSelect.toString()}
  class={`px-4 py-2 sm:px-6 border-b border-slate-200 dark:border-slate-800 flex items-center gap-2 overflow-x-auto ${containerClass}`}
>
  <span class="text-xs font-medium text-slate-500 shrink-0">{label}</span>
  <div class="flex items-center gap-1 flex-nowrap">
    {
      filters.map((filter) => (
        <button
          id={filter.id}
          data-filter-button
          data-active={filter.active ? 'true' : 'false'}
          class={`px-2 py-1 text-xs rounded transition-colors shrink-0 ${
            filter.active
              ? 'bg-accent text-white'
              : 'bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700'
          }`}
        >
          {filter.label}
        </button>
      ))
    }
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const containers = document.querySelectorAll('[data-multi-select]');

    containers.forEach((container) => {
      const multiSelect = container.getAttribute('data-multi-select') === 'true';
      const buttons = container.querySelectorAll('[data-filter-button]');

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          const isActive = button.getAttribute('data-active') === 'true';

          if (multiSelect) {
            // Multi-select mode: toggle individual button
            toggleButton(button, !isActive);
          } else {
            // Single-select mode: deactivate all, activate clicked
            buttons.forEach((btn) => toggleButton(btn, false));
            toggleButton(button, true);
          }

          // Dispatch custom event with filter state
          const activeFilters = Array.from(buttons)
            .filter((btn) => btn.getAttribute('data-active') === 'true')
            .map((btn) => btn.id);

          container.dispatchEvent(
            new CustomEvent('filter-change', {
              detail: { activeFilters },
              bubbles: true,
            })
          );
        });
      });
    });

    function toggleButton(button: Element, active: boolean) {
      button.setAttribute('data-active', active.toString());

      if (active) {
        button.classList.remove(
          'bg-slate-100',
          'dark:bg-slate-800',
          'text-slate-600',
          'dark:text-slate-300',
          'hover:bg-slate-200',
          'dark:hover:bg-slate-700'
        );
        button.classList.add('bg-accent', 'text-white');
      } else {
        button.classList.remove('bg-accent', 'text-white');
        button.classList.add(
          'bg-slate-100',
          'dark:bg-slate-800',
          'text-slate-600',
          'dark:text-slate-300',
          'hover:bg-slate-200',
          'dark:hover:bg-slate-700'
        );
      }
    }
  });
</script>
