---
import type { BaseProps, ValidationProps, SizeProps } from '../utils/types';
import { mergeTailwindClasses } from '../utils/cn';

export interface Props extends BaseProps, ValidationProps, SizeProps {
  label?: string;
  description?: string;
  required?: boolean;
  layout?: 'vertical' | 'horizontal';
  labelWidth?: '1/4' | '1/3' | '1/2';
}

const {
  label,
  description,
  required = false,
  layout = 'vertical',
  labelWidth = '1/3',
  size = 'md',
  error,
  warning,
  success,
  hint,
  className = '',
  ...props
} = Astro.props;

// Size-based spacing
const sizeClasses = {
  xs: 'gap-1',
  sm: 'gap-2',
  md: 'gap-3',
  lg: 'gap-4',
  xl: 'gap-5',
};

// Layout classes
const layoutClasses = {
  vertical: 'flex flex-col',
  horizontal: 'flex flex-row items-start',
};

// Label width for horizontal layout
const labelWidthClasses = {
  '1/4': 'w-1/4',
  '1/3': 'w-1/3',
  '1/2': 'w-1/2',
};

// Generate unique ID for accessibility
const fieldId = props.id || `field-${Math.random().toString(36).substring(2, 11)}`;

// Computed classes
const fieldClasses = mergeTailwindClasses(layoutClasses[layout], sizeClasses[size], className);

const labelClasses = mergeTailwindClasses(
  'block text-sm font-medium text-slate-700 dark:text-slate-300',
  layout === 'horizontal' && labelWidthClasses[labelWidth],
  layout === 'horizontal' && 'pt-2'
);

const contentClasses = mergeTailwindClasses(layout === 'horizontal' && 'flex-1');
---

<div class={fieldClasses} {...props}>
  {
    label && (
      <label for={fieldId} class={labelClasses}>
        {label}
        {required && (
          <span class="text-red-500 ml-1" aria-label="Required">
            *
          </span>
        )}
      </label>
    )
  }

  <div class={contentClasses}>
    {description && <p class="text-sm text-slate-500 dark:text-slate-400 mb-2">{description}</p>}

    <slot id={fieldId} />

    {/* Validation messages */}
    {
      error && (
        <p class="mt-1 text-sm text-red-600 dark:text-red-400 flex items-center gap-1">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
          {error}
        </p>
      )
    }

    {
      warning && !error && (
        <p class="mt-1 text-sm text-amber-600 dark:text-amber-400 flex items-center gap-1">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
            />
          </svg>
          {warning}
        </p>
      )
    }

    {
      success && !error && !warning && (
        <p class="mt-1 text-sm text-green-600 dark:text-green-400 flex items-center gap-1">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
          {success}
        </p>
      )
    }

    {
      hint && !error && !warning && !success && (
        <p class="mt-1 text-sm text-slate-500 dark:text-slate-400">{hint}</p>
      )
    }
  </div>
</div>
