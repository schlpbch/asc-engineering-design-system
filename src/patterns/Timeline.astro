---
import Card from '../components/Card.astro';
import Badge from '../components/Badge.astro';
import Stack from '../components/Stack.astro';
import PageSection from './PageSection.astro';
import type { TimelineItem } from '../utils/types';

export interface Props {
  items: TimelineItem[];
  id?: string;
  title?: string;
  border?: boolean;
}

const { items, id = 'timeline', title = 'Experience', border = false } = Astro.props;
const isCurrent = (period: string) => period.includes('Present');
---

<PageSection id={id} title={title} border={border}>
  <div class="relative pl-8 space-y-8">
    <div
      class="absolute left-[6px] top-0 bottom-0 w-0.5 bg-gradient-to-b from-accent-500 via-accent-500 to-slate-200 dark:to-slate-700"
    />

    {
      items.map((item) => (
        <div class="relative">
          <div
            class:list={[
              'absolute -left-[18px] top-1 w-3 h-3 rounded-full border-4 border-white dark:border-slate-900',
              isCurrent(item.period) ? 'bg-accent-500 animate-pulse' : 'bg-accent-500',
            ]}
          />

          <Card variant="default" size="md">
            <Stack
              direction="horizontal"
              align="start"
              justify="between"
              className="flex-col sm:flex-row mb-3"
            >
              <div>
                <h3 class="font-semibold text-slate-900 dark:text-white">{item.title}</h3>
                <p class="text-sm text-accent-700 dark:text-accent-400">
                  {item.company} · {item.location}
                </p>
              </div>
              <Badge intent="secondary" variant="outline" size="sm" shape="pill">
                {item.period}
              </Badge>
            </Stack>
            <Stack direction="vertical" size="xs">
              {item.bullets.map((b) => (
                <p class="text-sm text-slate-600 dark:text-slate-400 flex gap-2">
                  <span class="text-accent-500 mt-0.5 shrink-0">›</span>
                  <Fragment set:html={b} />
                </p>
              ))}
            </Stack>
          </Card>
        </div>
      ))
    }
  </div>
</PageSection>
