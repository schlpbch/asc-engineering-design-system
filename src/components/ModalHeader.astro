---
export interface Props {
  title: string;
  subtitle?: string;
  closeButtonId?: string;
}

const { title, subtitle, closeButtonId = 'close-modal-btn' } = Astro.props;
---

<div
  class="flex items-center justify-between px-4 py-3 sm:px-6 sm:py-4 border-b border-slate-200 dark:border-slate-800"
>
  <div class="min-w-0 flex-1 pr-2">
    <h3 class="text-base sm:text-lg font-bold text-slate-900 dark:text-white">
      {title}
    </h3>
    {
      subtitle && (
        <p class="text-xs sm:text-sm text-slate-500 dark:text-slate-400 mt-0.5">{subtitle}</p>
      )
    }
  </div>
  <button
    id={closeButtonId}
    class="p-2.5 sm:p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 shrink-0"
  >
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"
      ></path>
    </svg>
  </button>
</div>
