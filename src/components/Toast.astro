---
import type { BaseProps, IntentProps } from '../utils/types';
import { mergeTailwindClasses } from '../utils/cn';

export interface Props extends BaseProps, IntentProps {
  title?: string;
  message: string;
  dismissible?: boolean;
  duration?: number;
  position?: 'top-right' | 'top-left' | 'bottom-right' | 'bottom-left' | 'top-center' | 'bottom-center';
}

const {
  intent = 'info',
  title,
  message,
  dismissible = true,
  duration = 5000,
  position = 'bottom-right',
  className = '',
  ...props
} = Astro.props;

const toastId = props.id || `toast-${Math.random().toString(36).substring(2, 11)}`;

// Position classes for the container
const positionClasses = {
  'top-right': 'top-4 right-4',
  'top-left': 'top-4 left-4',
  'bottom-right': 'bottom-4 right-4',
  'bottom-left': 'bottom-4 left-4',
  'top-center': 'top-4 left-1/2 -translate-x-1/2',
  'bottom-center': 'bottom-4 left-1/2 -translate-x-1/2',
};

// Intent border colors
const intentBorderColors = {
  primary: 'border-l-accent-500',
  success: 'border-l-green-500',
  warning: 'border-l-amber-500',
  error: 'border-l-red-500',
  info: 'border-l-blue-500',
  secondary: 'border-l-slate-500',
};

// Intent icon colors
const intentIconColors = {
  primary: 'text-accent-500',
  success: 'text-green-500',
  warning: 'text-amber-500',
  error: 'text-red-500',
  info: 'text-blue-500',
  secondary: 'text-slate-500',
};

const toastClasses = mergeTailwindClasses(
  'flex items-start gap-3 w-full max-w-sm bg-white dark:bg-slate-900 rounded-lg shadow-lg border border-slate-200 dark:border-slate-700 border-l-4 p-4',
  intentBorderColors[intent] || intentBorderColors.info,
  className
);

const containerClasses = mergeTailwindClasses(
  'fixed z-[9999] flex flex-col gap-2 pointer-events-none',
  positionClasses[position]
);
---

<div class={containerClasses} data-toast-container data-position={position}>
  <div
    id={toastId}
    class={mergeTailwindClasses(toastClasses, 'pointer-events-auto transition-all duration-300 ease-out')}
    role="alert"
    aria-live="assertive"
    aria-atomic="true"
    data-duration={duration}
    data-dismissible={dismissible}
  >
    <!-- Icon -->
    <svg
      class={mergeTailwindClasses('w-5 h-5 flex-shrink-0 mt-0.5', intentIconColors[intent] || intentIconColors.info)}
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
      aria-hidden="true"
    >
      {intent === 'success' ? (
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
      ) : intent === 'warning' ? (
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      ) : intent === 'error' ? (
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
      ) : (
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      )}
    </svg>

    <!-- Content -->
    <div class="flex-1 min-w-0">
      {title && (
        <p class="text-sm font-semibold text-slate-900 dark:text-white">{title}</p>
      )}
      <p class={mergeTailwindClasses('text-sm text-slate-600 dark:text-slate-400', title && 'mt-0.5')}>{message}</p>
    </div>

    <!-- Dismiss button -->
    {dismissible && (
      <button
        type="button"
        class="flex-shrink-0 p-1 rounded-md text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-400"
        aria-label="Dismiss notification"
        data-toast-dismiss={toastId}
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    )}
  </div>
</div>

<script>
  function dismissToast(toastEl: HTMLElement) {
    toastEl.style.opacity = '0';
    toastEl.style.transform = 'translateX(100%)';
    const height = toastEl.offsetHeight;
    toastEl.style.maxHeight = height + 'px';
    setTimeout(() => {
      toastEl.style.maxHeight = '0';
      toastEl.style.paddingTop = '0';
      toastEl.style.paddingBottom = '0';
      toastEl.style.marginBottom = '0';
      toastEl.style.overflow = 'hidden';
    }, 300);
    setTimeout(() => {
      const container = toastEl.closest('[data-toast-container]') as HTMLElement | null;
      toastEl.remove();
      if (container && !container.querySelector('[role="alert"]')) {
        container.remove();
      }
    }, 600);
  }

  function initToast(toastEl: HTMLElement) {
    const duration = parseInt(toastEl.dataset.duration || '5000', 10);
    if (duration > 0) {
      setTimeout(() => dismissToast(toastEl), duration);
    }
  }

  // Init existing toasts
  document.querySelectorAll<HTMLElement>('[role="alert"][data-duration]').forEach(initToast);

  // Dismiss button handler
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-toast-dismiss]');
    if (btn) {
      const id = btn.dataset.toastDismiss;
      const toastEl = id ? document.getElementById(id) : null;
      if (toastEl) dismissToast(toastEl);
    }
  });

  // Global showToast function for programmatic use
  type ToastIntent = 'primary' | 'success' | 'warning' | 'error' | 'info';
  type ToastPosition = 'top-right' | 'top-left' | 'bottom-right' | 'bottom-left' | 'top-center' | 'bottom-center';

  interface ToastOptions {
    message: string;
    title?: string;
    intent?: ToastIntent;
    duration?: number;
    dismissible?: boolean;
    position?: ToastPosition;
  }

  (window as any).showToast = function(options: ToastOptions) {
    const {
      message,
      title,
      intent = 'info',
      duration = 5000,
      dismissible = true,
      position = 'bottom-right',
    } = options;

    const borderColorMap: Record<ToastIntent, string> = {
      primary: '#14b8a6',
      success: '#22c55e',
      warning: '#f59e0b',
      error: '#ef4444',
      info: '#3b82f6',
    };

    const iconColorMap: Record<ToastIntent, string> = {
      primary: '#14b8a6',
      success: '#22c55e',
      warning: '#f59e0b',
      error: '#ef4444',
      info: '#3b82f6',
    };

    const positionStyleMap: Record<ToastPosition, Partial<CSSStyleDeclaration>> = {
      'top-right': { top: '1rem', right: '1rem' },
      'top-left': { top: '1rem', left: '1rem' },
      'bottom-right': { bottom: '1rem', right: '1rem' },
      'bottom-left': { bottom: '1rem', left: '1rem' },
      'top-center': { top: '1rem', left: '50%', transform: 'translateX(-50%)' },
      'bottom-center': { bottom: '1rem', left: '50%', transform: 'translateX(-50%)' },
    };

    // Find or create container
    let container = document.querySelector<HTMLElement>(`[data-toast-container][data-position="${position}"]`);
    if (!container) {
      container = document.createElement('div');
      container.setAttribute('data-toast-container', '');
      container.setAttribute('data-position', position);
      container.style.cssText = 'position:fixed;z-index:9999;display:flex;flex-direction:column;gap:0.5rem;pointer-events:none;';
      const posStyle = positionStyleMap[position] || positionStyleMap['bottom-right'];
      Object.assign(container.style, posStyle);
      document.body.appendChild(container);
    }

    const id = `toast-${Math.random().toString(36).substring(2, 11)}`;
    const toastEl = document.createElement('div');
    toastEl.id = id;
    toastEl.setAttribute('role', 'alert');
    toastEl.setAttribute('aria-live', 'assertive');
    toastEl.setAttribute('aria-atomic', 'true');
    toastEl.setAttribute('data-duration', String(duration));
    toastEl.setAttribute('data-dismissible', String(dismissible));
    toastEl.style.cssText = [
      'display:flex;align-items:flex-start;gap:0.75rem;width:100%;max-width:24rem;',
      'background:white;border-radius:0.5rem;box-shadow:0 10px 15px -3px rgba(0,0,0,.1);',
      'border:1px solid #e2e8f0;border-left:4px solid ' + (borderColorMap[intent] || '#3b82f6') + ';',
      'padding:1rem;pointer-events:auto;transition:opacity .3s,transform .3s;',
    ].join('');

    // Icon svg
    const svgNS = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(svgNS, 'svg');
    svg.setAttribute('width', '20');
    svg.setAttribute('height', '20');
    svg.setAttribute('viewBox', '0 0 24 24');
    svg.setAttribute('fill', 'none');
    svg.setAttribute('stroke', iconColorMap[intent] || '#3b82f6');
    svg.setAttribute('stroke-width', '2');
    svg.setAttribute('aria-hidden', 'true');
    svg.style.cssText = 'flex-shrink:0;margin-top:0.125rem;';
    const path = document.createElementNS(svgNS, 'path');
    path.setAttribute('stroke-linecap', 'round');
    path.setAttribute('stroke-linejoin', 'round');
    if (intent === 'success') {
      path.setAttribute('d', 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z');
    } else if (intent === 'warning') {
      path.setAttribute('d', 'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z');
    } else if (intent === 'error') {
      path.setAttribute('d', 'M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z');
    } else {
      path.setAttribute('d', 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z');
    }
    svg.appendChild(path);
    toastEl.appendChild(svg);

    // Content div
    const contentDiv = document.createElement('div');
    contentDiv.style.cssText = 'flex:1;min-width:0;';
    if (title) {
      const titleEl = document.createElement('p');
      titleEl.style.cssText = 'font-size:.875rem;font-weight:600;color:#0f172a;margin:0 0 .125rem;';
      titleEl.textContent = title;
      contentDiv.appendChild(titleEl);
    }
    const msgEl = document.createElement('p');
    msgEl.style.cssText = 'font-size:.875rem;color:#475569;margin:0;';
    msgEl.textContent = message;
    contentDiv.appendChild(msgEl);
    toastEl.appendChild(contentDiv);

    // Dismiss button
    if (dismissible) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.setAttribute('aria-label', 'Dismiss notification');
      btn.setAttribute('data-toast-dismiss', id);
      btn.style.cssText = 'flex-shrink:0;padding:.25rem;border-radius:.375rem;background:none;border:none;cursor:pointer;color:#94a3b8;';
      const btnSvg = document.createElementNS(svgNS, 'svg');
      btnSvg.setAttribute('width', '16');
      btnSvg.setAttribute('height', '16');
      btnSvg.setAttribute('viewBox', '0 0 24 24');
      btnSvg.setAttribute('fill', 'none');
      btnSvg.setAttribute('stroke', 'currentColor');
      btnSvg.setAttribute('stroke-width', '2');
      btnSvg.setAttribute('aria-hidden', 'true');
      const closePath = document.createElementNS(svgNS, 'path');
      closePath.setAttribute('stroke-linecap', 'round');
      closePath.setAttribute('stroke-linejoin', 'round');
      closePath.setAttribute('d', 'M6 18L18 6M6 6l12 12');
      btnSvg.appendChild(closePath);
      btn.appendChild(btnSvg);
      toastEl.appendChild(btn);
    }

    container.appendChild(toastEl);
    initToast(toastEl);
  };
</script>
