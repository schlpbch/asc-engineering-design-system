---
// Skeleton loading component for dashboard cards
export interface Props {
  type?: 'card' | 'list' | 'service';
  count?: number;
}

const { type = 'list', count = 3 } = Astro.props;
---

{
  type === 'card' && (
    <div class="animate-pulse space-y-4">
      <div class="h-8 bg-slate-200 dark:bg-slate-700 rounded-lg w-3/4" />
      <div class="h-4 bg-slate-200 dark:bg-slate-700 rounded w-1/2" />
      <div class="space-y-3">
        {Array.from({ length: count }).map(() => (
          <div class="h-16 bg-slate-200 dark:bg-slate-700 rounded-lg" />
        ))}
      </div>
    </div>
  )
}

{
  type === 'list' && (
    <div class="space-y-3">
      {Array.from({ length: count }).map(() => (
        <div class="animate-pulse flex items-start gap-2">
          <div class="w-2 h-2 bg-slate-300 dark:bg-slate-600 rounded-full mt-2" />
          <div class="flex-1 space-y-2">
            <div class="h-4 bg-slate-200 dark:bg-slate-700 rounded w-3/4" />
            <div class="h-3 bg-slate-200 dark:bg-slate-700 rounded w-full" />
          </div>
        </div>
      ))}
    </div>
  )
}

{
  type === 'service' && (
    <div class="grid sm:grid-cols-2 gap-6">
      {Array.from({ length: count }).map(() => (
        <div class="animate-pulse p-4 rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700">
          <div class="flex items-start gap-3">
            <div class="w-10 h-10 bg-slate-200 dark:bg-slate-700 rounded-xl" />
            <div class="flex-1 space-y-2">
              <div class="h-5 bg-slate-200 dark:bg-slate-700 rounded w-1/2" />
              <div class="h-3 bg-slate-200 dark:bg-slate-700 rounded w-3/4" />
              <div class="h-3 bg-slate-200 dark:bg-slate-700 rounded w-1/4" />
            </div>
          </div>
        </div>
      ))}
    </div>
  )
}
