---
export interface Props {
  title: string;
  className?: string;
}

const { title, className = '' } = Astro.props;
---

<div
  class={`px-4 py-2 border-b border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-800/50 ${className}`}
>
  <h4 class="text-sm font-semibold text-slate-900 dark:text-white flex items-center gap-2">
    <slot name="icon" />
    {title}
  </h4>
</div>
