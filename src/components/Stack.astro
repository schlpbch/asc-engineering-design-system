---
import type { BaseProps, SizeProps } from '../utils/types';
import { mergeTailwindClasses } from '../utils/cn';

export interface Props extends BaseProps, SizeProps {
  direction?: 'horizontal' | 'vertical';
  align?: 'start' | 'center' | 'end' | 'stretch';
  justify?: 'start' | 'center' | 'end' | 'between' | 'around' | 'evenly';
  wrap?: boolean;
  as?: string;
}

const {
  direction = 'vertical',
  size = 'md',
  align = 'stretch',
  justify = 'start',
  wrap = false,
  as: Component = 'div',
  className = '',
  ...props
} = Astro.props;

// Direction classes
const directionClasses = {
  horizontal: 'flex-row',
  vertical: 'flex-col',
};

// Size-based spacing (gap)
const sizeClasses = {
  xs: 'gap-1',
  sm: 'gap-2',
  md: 'gap-4',
  lg: 'gap-6',
  xl: 'gap-8',
};

// Alignment classes
const alignClasses = {
  start: 'items-start',
  center: 'items-center',
  end: 'items-end',
  stretch: 'items-stretch',
};

// Justify classes
const justifyClasses = {
  start: 'justify-start',
  center: 'justify-center',
  end: 'justify-end',
  between: 'justify-between',
  around: 'justify-around',
  evenly: 'justify-evenly',
};

// Base stack classes
const baseClasses = 'flex';

// Computed classes
const stackClasses = mergeTailwindClasses(
  baseClasses,
  directionClasses[direction as keyof typeof directionClasses],
  sizeClasses[size as keyof typeof sizeClasses],
  alignClasses[align as keyof typeof alignClasses],
  justifyClasses[justify as keyof typeof justifyClasses],
  wrap && 'flex-wrap',
  className
);
---

<Component class={stackClasses} {...props}>
  <slot />
</Component>
