---
import type { BaseProps } from '../utils/types';
import { mergeTailwindClasses } from '../utils/cn';

export interface TableHeader {
  key: string;
  label: string;
  align?: 'left' | 'center' | 'right';
}

export interface Props extends BaseProps {
  headers: TableHeader[];
  rows: Array<Record<string, string>>;
  striped?: boolean;
  hoverable?: boolean;
  bordered?: boolean;
  stickyHeader?: boolean;
  caption?: string;
}

const {
  headers,
  rows,
  striped = false,
  hoverable = true,
  bordered = false,
  stickyHeader = false,
  caption,
  className = '',
  ...props
} = Astro.props;

// Alignment classes
const alignClasses = {
  left: 'text-left',
  center: 'text-center',
  right: 'text-right',
};

const tableClasses = mergeTailwindClasses(
  'w-full text-sm text-left',
  bordered ? 'border border-slate-200 dark:border-slate-700' : '',
  className
);

const theadClasses = mergeTailwindClasses(
  'bg-slate-50 dark:bg-slate-800',
  stickyHeader ? 'sticky top-0 z-10' : ''
);

const thClasses = (header: TableHeader) => mergeTailwindClasses(
  'px-4 py-3 text-xs font-semibold uppercase tracking-wider text-slate-500 dark:text-slate-400',
  alignClasses[header.align || 'left'],
  bordered ? 'border-b border-slate-200 dark:border-slate-700' : 'border-b border-slate-200 dark:border-slate-700'
);

const tdClasses = (header: TableHeader, rowIndex: number) => mergeTailwindClasses(
  'px-4 py-3 text-slate-700 dark:text-slate-300',
  alignClasses[header.align || 'left'],
  bordered ? 'border border-slate-200 dark:border-slate-700' : 'border-b border-slate-100 dark:border-slate-800',
  striped && rowIndex % 2 === 1 ? 'bg-slate-50/50 dark:bg-slate-800/50' : ''
);

const trClasses = (rowIndex: number) => mergeTailwindClasses(
  'transition-colors',
  hoverable ? 'hover:bg-slate-50 dark:hover:bg-slate-800/50' : ''
);
---

<div class="w-full overflow-x-auto rounded-lg" {...props}>
  <table class={tableClasses}>
    {caption && (
      <caption class="mb-2 text-sm text-slate-500 dark:text-slate-400 text-left px-1">
        {caption}
      </caption>
    )}

    <thead class={theadClasses}>
      <tr>
        {headers.map((header) => (
          <th scope="col" class={thClasses(header)}>
            {header.label}
          </th>
        ))}
      </tr>
    </thead>

    <tbody class="bg-white dark:bg-slate-900 divide-y divide-slate-100 dark:divide-slate-800">
      {rows.map((row, rowIndex) => (
        <tr class={trClasses(rowIndex)}>
          {headers.map((header) => (
            <td class={tdClasses(header, rowIndex)} set:html={row[header.key] ?? ''} />
          ))}
        </tr>
      ))}
      {rows.length === 0 && (
        <tr>
          <td
            colspan={headers.length}
            class="px-4 py-8 text-center text-slate-400 dark:text-slate-600"
          >
            No data available
          </td>
        </tr>
      )}
    </tbody>
  </table>
</div>
