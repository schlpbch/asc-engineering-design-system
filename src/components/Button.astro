---
import type {
  BaseProps,
  SizeProps,
  IntentProps,
  LoadingProps,
  DisabledProps,
  IconProps,
} from '../utils/types';
import { mergeTailwindClasses } from '../utils/cn';
import LoadingSpinner from './LoadingSpinner.astro';

export interface Props
  extends BaseProps, SizeProps, IntentProps, LoadingProps, DisabledProps, IconProps {
  variant?: 'solid' | 'outline' | 'ghost' | 'link';
  fullWidth?: boolean;
  type?: 'button' | 'submit' | 'reset';
  href?: string;
  target?: '_blank' | '_self' | '_parent' | '_top';
  rel?: string;
  onclick?: string;
}

const {
  variant = 'solid',
  size = 'md',
  intent = 'primary',
  fullWidth = false,
  loading = false,
  disabled = false,
  type = 'button',
  className = '',
  href,
  target,
  rel,
  icon,
  iconPosition = 'left',
  loadingText,
  ...props
} = Astro.props;

// Size variants
const sizeClasses = {
  xs: 'px-2 py-1 text-xs gap-1',
  sm: 'px-3 py-1.5 text-sm gap-1.5',
  md: 'px-4 py-2 text-sm gap-2',
  lg: 'px-6 py-3 text-base gap-2',
  xl: 'px-8 py-4 text-lg gap-3',
};

// Intent + Variant combinations
const intentVariants = {
  solid: {
    primary: 'bg-accent-500 hover:bg-accent-600 text-white border-transparent',
    secondary: 'bg-slate-500 hover:bg-slate-600 text-white border-transparent',
    success: 'bg-green-500 hover:bg-green-600 text-white border-transparent',
    warning: 'bg-amber-500 hover:bg-amber-600 text-white border-transparent',
    error: 'bg-red-500 hover:bg-red-600 text-white border-transparent',
    info: 'bg-blue-500 hover:bg-blue-600 text-white border-transparent',
  },
  outline: {
    primary: 'border-accent-500 text-accent-600 hover:bg-accent-50 dark:hover:bg-accent-950',
    secondary:
      'border-slate-300 text-slate-700 hover:bg-slate-50 dark:border-slate-600 dark:text-slate-300 dark:hover:bg-slate-800',
    success: 'border-green-500 text-green-600 hover:bg-green-50 dark:hover:bg-green-950',
    warning: 'border-amber-500 text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-950',
    error: 'border-red-500 text-red-600 hover:bg-red-50 dark:hover:bg-red-950',
    info: 'border-blue-500 text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-950',
  },
  ghost: {
    primary: 'text-accent-600 hover:bg-accent-50 dark:hover:bg-accent-950 border-transparent',
    secondary:
      'text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800 border-transparent',
    success: 'text-green-600 hover:bg-green-50 dark:hover:bg-green-950 border-transparent',
    warning: 'text-amber-600 hover:bg-amber-50 dark:hover:bg-amber-950 border-transparent',
    error: 'text-red-600 hover:bg-red-50 dark:hover:bg-red-950 border-transparent',
    info: 'text-blue-600 hover:bg-blue-50 dark:hover:bg-blue-950 border-transparent',
  },
  link: {
    primary:
      'text-accent-600 hover:text-accent-700 underline-offset-4 hover:underline p-0 h-auto border-transparent',
    secondary:
      'text-slate-600 hover:text-slate-700 underline-offset-4 hover:underline p-0 h-auto border-transparent',
    success:
      'text-green-600 hover:text-green-700 underline-offset-4 hover:underline p-0 h-auto border-transparent',
    warning:
      'text-amber-600 hover:text-amber-700 underline-offset-4 hover:underline p-0 h-auto border-transparent',
    error:
      'text-red-600 hover:text-red-700 underline-offset-4 hover:underline p-0 h-auto border-transparent',
    info: 'text-blue-600 hover:text-blue-700 underline-offset-4 hover:underline p-0 h-auto border-transparent',
  },
};

// Base button classes
const baseClasses =
  'inline-flex items-center justify-center font-medium transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 disabled:pointer-events-none disabled:opacity-50';

// Computed classes
const variantClasses = intentVariants[variant][intent];
const sizeClass = sizeClasses[size];
const widthClass = fullWidth ? 'w-full' : '';
const roundedClass = variant === 'link' ? '' : 'rounded-md border';

const buttonClasses = mergeTailwindClasses(
  baseClasses,
  roundedClass,
  sizeClass,
  variantClasses,
  widthClass,
  loading && 'pointer-events-none',
  className
);

// Determine if we should render as link or button
const isLink = !!href && !disabled && !loading;
const Component = isLink ? 'a' : 'button';

// Link-specific props
const linkProps = isLink
  ? {
      href,
      target,
      rel: target === '_blank' ? 'noopener noreferrer' : rel,
    }
  : {};

// Button-specific props
const buttonProps = !isLink
  ? {
      type,
      disabled: disabled || loading,
    }
  : {};
---

<Component class={buttonClasses} {...linkProps} {...buttonProps} {...props}>
  {
    loading && (
      <LoadingSpinner
        size={size === 'xs' || size === 'sm' ? 'sm' : 'md'}
        className="text-current"
        message=""
      />
    )
  }

  {
    icon && iconPosition === 'left' && !loading && (
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <use href={`#icon-${icon}`} />
      </svg>
    )
  }

  <span class={loading ? 'sr-only' : ''}>
    {loading && loadingText ? loadingText : <slot />}
  </span>

  {
    icon && iconPosition === 'right' && !loading && (
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <use href={`#icon-${icon}`} />
      </svg>
    )
  }
</Component>
