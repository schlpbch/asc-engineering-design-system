---
import type { BaseProps } from '../utils/types';
import { mergeTailwindClasses } from '../utils/cn';

export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props extends BaseProps {
  items: BreadcrumbItem[];
  separator?: 'slash' | 'chevron' | 'dot';
  size?: 'sm' | 'md' | 'lg';
}

const {
  items,
  separator = 'chevron',
  size = 'md',
  className = '',
  ...props
} = Astro.props;

// Size classes
const sizeClasses = {
  sm: 'text-xs',
  md: 'text-sm',
  lg: 'text-base',
};

const navClasses = mergeTailwindClasses('flex', sizeClasses[size], className);
---

<nav aria-label="Breadcrumb" class={navClasses} {...props}>
  <ol
    class="flex flex-wrap items-center gap-1"
    itemscope
    itemtype="https://schema.org/BreadcrumbList"
  >
    {items.map((item, index) => {
      const isLast = index === items.length - 1;
      const position = index + 1;

      return (
        <li
          class="flex items-center gap-1"
          itemprop="itemListElement"
          itemscope
          itemtype="https://schema.org/ListItem"
        >
          {isLast ? (
            <span
              class="font-medium text-slate-900 dark:text-white truncate max-w-[200px]"
              aria-current="page"
              itemprop="name"
            >
              {item.label}
            </span>
          ) : (
            <>
              <a
                href={item.href || '#'}
                class="text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-colors truncate max-w-[200px]"
                itemprop="item"
              >
                <span itemprop="name">{item.label}</span>
              </a>

              <!-- Separator -->
              <span class="text-slate-400 dark:text-slate-600 select-none flex-shrink-0" aria-hidden="true">
                {separator === 'slash' ? (
                  <span>/</span>
                ) : separator === 'dot' ? (
                  <span class="w-1 h-1 rounded-full bg-slate-400 dark:bg-slate-600 inline-block" />
                ) : (
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                )}
              </span>
            </>
          )}

          <meta itemprop="position" content={String(position)} />
        </li>
      );
    })}
  </ol>
</nav>
