---
import type { BaseProps, SizeProps } from '../utils/types';
import { mergeTailwindClasses } from '../utils/cn';

export interface Props extends BaseProps, SizeProps {
  variant?: 'default' | 'outlined' | 'elevated' | 'filled';
  interactive?: boolean;
  as?: string;
}

const {
  variant = 'default',
  size = 'md',
  interactive = false,
  as: Component = 'div',
  className = '',
  ...props
} = Astro.props;

// Size variants - affects padding
const sizeClasses = {
  xs: 'p-3',
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8',
  xl: 'p-10',
};

// Variant styles
const variantClasses = {
  default: 'bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700',
  outlined: 'bg-transparent border-2 border-slate-200 dark:border-slate-700',
  elevated: 'bg-white dark:bg-slate-900 shadow-lg border border-slate-200 dark:border-slate-700',
  filled: 'bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700',
};

// Interactive styles
const interactiveClasses = interactive
  ? 'cursor-pointer transition-all duration-200 hover:shadow-md hover:scale-[1.02] focus:outline-none focus:ring-2 focus:ring-accent-500 focus:ring-offset-2'
  : '';

// Base card classes
const baseClasses = 'rounded-lg';

// Computed classes
const cardClasses = mergeTailwindClasses(
  baseClasses,
  variantClasses[variant as keyof typeof variantClasses],
  sizeClasses[size as keyof typeof sizeClasses],
  interactiveClasses,
  className
);
---

<Component
  class={cardClasses}
  tabindex={interactive ? 0 : undefined}
  role={interactive ? 'button' : undefined}
  {...props}
>
  <slot />
</Component>
