---
export interface Props {
  helpText?: string;
  closeText?: string;
  closeButtonId?: string;
  className?: string;
}

const {
  helpText,
  closeText = 'Close',
  closeButtonId = 'modal-close-btn',
  className = '',
} = Astro.props;
---

<div
  class={`px-4 py-3 sm:px-6 sm:py-4 border-t border-slate-200 dark:border-slate-800 flex flex-col-reverse sm:flex-row justify-between items-center gap-2 sm:gap-3 bg-slate-50/50 dark:bg-slate-900/50 ${className}`}
>
  {helpText && <p class="text-xs text-slate-500">{helpText}</p>}
  <div class="flex gap-2 sm:gap-3">
    <slot name="actions" />
    <button
      id={closeButtonId}
      class="px-4 py-2 text-sm font-medium text-slate-700 dark:text-slate-300 hover:text-slate-900 dark:hover:text-white transition-colors rounded-lg"
    >
      {closeText}
    </button>
  </div>
</div>
