---
import type { BaseProps } from '../utils/types';
import { mergeTailwindClasses } from '../utils/cn';

export interface Props extends BaseProps {
  src?: string;
  alt?: string;
  initials?: string;
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  shape?: 'circle' | 'rounded';
  status?: 'online' | 'offline' | 'busy' | 'away';
}

const {
  src,
  alt = '',
  initials,
  size = 'md',
  shape = 'circle',
  status,
  className = '',
  ...props
} = Astro.props;

// Size variants
const sizeClasses = {
  xs: 'w-6 h-6 text-xs',
  sm: 'w-8 h-8 text-sm',
  md: 'w-10 h-10 text-sm',
  lg: 'w-12 h-12 text-base',
  xl: 'w-16 h-16 text-lg',
};

// Status dot sizes
const dotSizeClasses = {
  xs: 'w-1.5 h-1.5',
  sm: 'w-2 h-2',
  md: 'w-2.5 h-2.5',
  lg: 'w-3 h-3',
  xl: 'w-3.5 h-3.5',
};

// Shape variants
const shapeClasses = {
  circle: 'rounded-full',
  rounded: 'rounded-lg',
};

// Status dot colors
const statusColors = {
  online: 'bg-green-500',
  offline: 'bg-slate-400',
  busy: 'bg-red-500',
  away: 'bg-amber-500',
};

const avatarClasses = mergeTailwindClasses(
  'relative inline-flex items-center justify-center flex-shrink-0 font-medium select-none overflow-hidden',
  sizeClasses[size],
  shapeClasses[shape],
  !src ? 'bg-accent-500 text-white' : 'bg-slate-200 dark:bg-slate-700',
  className
);
---

<span class="relative inline-flex" {...props}>
  <span class={avatarClasses}>
    {src ? (
      <img
        src={src}
        alt={alt}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    ) : initials ? (
      <span aria-label={alt || initials}>{initials}</span>
    ) : (
      <svg class="w-3/5 h-3/5 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
      </svg>
    )}
  </span>

  {status && (
    <span
      class={mergeTailwindClasses(
        'absolute bottom-0 right-0 block rounded-full ring-2 ring-white dark:ring-slate-900',
        dotSizeClasses[size],
        statusColors[status]
      )}
      aria-label={`Status: ${status}`}
    />
  )}
</span>
